# Version control
.git
.gitignore
.gitattributes

# Dependencies (installed inside the image / provided by volumes)
vendor
node_modules

# Environment & secrets — must never be baked into the image
.env
.env.backup

# Local tooling / editor
.claude
.idea
.vscode
.styleci.yml

# Docker build context noise
Dockerfile
docker-compose.yml
docker-compose.override.yml

# Runtime artifacts
public/hot
public/storage
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
npm-debug.log
yarn-error.log

# Docs are not needed at runtime
docs
